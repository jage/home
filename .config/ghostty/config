# Ghostty config
# https://github.com/ghostty-org/ghostty?tab=readme-ov-file#configuration

font-family = JetBrainsMonoNL Nerd Font Mono
font-size = 12
theme = dark:iTerm2 Solarized Dark,light:iTerm2 Solarized Light

unfocused-split-opacity = 0.95

window-padding-x = 4
window-padding-y = 4

keybind = global:alt+§=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0
